@model List<TaskDemo.Models.User_Master>

@{
    var userName = Context.Session.GetString("UserName");
}

@* <div class="d-flex justify-content-between align-items-center mb-3">
    <h1>User List</h1>
    <div>
        <span>Welcome, @userName!</span>
        <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger btn-sm ml-2">Logout</a>
    </div>
</div> *@

<a asp-action="Add" class="btn btn-success mb-2">Add New User</a>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>User List</h1>
    <div>
        <span>Welcome, @Context.Session.GetString("UserName")!</span>
        <a asp-controller="User" asp-action="Profile" class="btn btn-info btn-sm ml-2">Profile</a>
        <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger btn-sm ml-2">Logout</a>
    </div>
</div>
<input type="text" id="searchBox" class="form-control mb-3"
       placeholder="🔍 search by name or email..." />
<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Gender</th>
            <th>Education</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="userTableBody">
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>@user.Email</td>
                <td>@(user.GenderId == "M" ? "Male" : user.GenderId == "F" ? "Female" : "Other")</td>
                <td>@user.EducationName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-primary btn-sm">Edit</a>

                    <form asp-action="Delete" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('Are you sure you want to delete this user?');">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $("#searchBox").on("keyup", function () {
        let searchValue = $(this).val();

        $.ajax({
            url: '/User/SearchUsers',
            type: 'GET',
            data: { search: searchValue },
            success: function (data) {

                let rows = "";

                data.forEach(user => {
                    let gender = user.genderId === "M" ? "Male" :
                        user.genderId === "F" ? "Female" : "Other";

                    rows += `
                            <tr>
                                <td>${user.firstName}</td>
                                <td>${user.lastName}</td>
                                <td>${user.email}</td>
                                <td>${gender}</td>
                                <td>${user.educationName}</td>
                                <td>
                                    <a href="/User/Edit/${user.id}" class="btn btn-primary btn-sm">Edit</a>

                                    <form method="post" action="/User/Delete" style="display:inline;">
                                        <input type="hidden" name="id" value="${user.id}" />
                                        <button type="submit" class="btn btn-danger btn-sm"
                                            onclick="return confirm('Are you sure?')">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        `;
                });

                $("#userTableBody").html(rows);
            }
        });
    });
</script>