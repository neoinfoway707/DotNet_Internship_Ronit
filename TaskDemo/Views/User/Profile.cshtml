@model TaskDemo.Models.User_Master

<h2>My Profile</h2>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <p><strong>First Name:</strong> @Model.FirstName</p>
        <p><strong>Last Name:</strong> @Model.LastName</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Gender:</strong> @(Model.GenderId == "M" ? "Male" : Model.GenderId == "F" ? "Female" : "Other")</p>

    </div>
</div>

<div class="mt-3">
    <a asp-action="UserList" class="btn btn-secondary">Back to Users</a>
    <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger">Logout</a>
</div>